# =============================================================================
# haimin-issue-desk 환경변수 예시
# -----------------------------------------------------------------------------
# 로컬 개발은 .env.local 에 복사해서 사용.
# 실제 값은 절대 커밋하지 않는다.
# =============================================================================

# --- App ---------------------------------------------------------------------
# 공개 호스트(커스텀 도메인). vercel.app 기본 도메인은 내부 확인용.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# local | staging | production
APP_ENV="local"

# --- Database (PostgreSQL 16) ------------------------------------------------
# 국내 PostgreSQL 파일럿. SSL은 운영 환경에서 require.
DATABASE_URL="postgres://postgres:postgres@localhost:5432/haimin_issue_desk"

# --- Auth.js -----------------------------------------------------------------
# `openssl rand -base64 32` 등으로 강한 시크릿 생성
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# --- 초기 seed 계정 (db:seed 에서 사용) -------------------------------------
# 첫 배포 때 2개 생성. 로그인 후 반드시 재설정.
SEED_ADMIN_EMAIL="admin@haimin.local"
SEED_ADMIN_PASSWORD=""
SEED_EDITOR_EMAIL="editor@haimin.local"
SEED_EDITOR_PASSWORD=""

# --- Feature flags (DB 값이 우선, 없을 때 이 기본값으로 초기화) --------------
# voice 모듈: 초기 배포에서는 OFF
FEATURE_VOICE_DEFAULT="false"
# 선거모드: 2026-04-15 운영 상황을 반영해 기본 ON
FEATURE_ELECTION_MODE_DEFAULT="true"
# AI 연동: 키 없어도 앱이 돌아야 하므로 기본 OFF
FEATURE_AI_DEFAULT="false"

# --- 외부 데이터 소스 (v1 수집기; 없어도 앱은 동작) ---------------------------
ASSEMBLY_API_KEY=""
DATA_GO_KR_SERVICE_KEY=""
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# --- AI (선택) ---------------------------------------------------------------
ANTHROPIC_API_KEY=""

# --- Cloudflare Turnstile (voice, 초기 OFF라 빈 값 허용) ---------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- Rate limit (추상화만 v1, Upstash 등은 나중에) ---------------------------
RATE_LIMIT_BACKEND="memory"

# --- Cron -------------------------------------------------------------------
CRON_SECRET=""
